# Database SQLite (file lokal, langsung jalan).
DATABASE_URL="file:./dev.db"

# Kunci rahasia untuk menandatangani sesi login (JWT).
# WAJIB ganti dengan string acak panjang di produksi.
AUTH_SECRET="ganti-dengan-kunci-rahasia-acak-yang-panjang"

# Port yang diekspos ke luar container (default: 3000).
# Ganti jika port 3000 sudah dipakai oleh aplikasi lain di server.
APP_PORT=3000
